{
  "name": "nexchat-socket-server",
  "version": "1.0.0",
  "private": true,
  "description": "Standalone Socket.IO + WebRTC signalling server for NexChat. Deploy to Railway/Fly/Render.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.95.3",
    "cookie": "^1.1.1",
    "jose": "^6.1.3",
    "socket.io": "^4.7.4",
    "web-push": "^3.6.7",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/web-push": "^3.6.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
